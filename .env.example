# ============================================================
# CryptoTracker BMZ — Environment Variables
# Salin file ini menjadi .env dan isi nilainya.
# JANGAN commit .env yang asli ke repository!
# ============================================================

# ─── Keamanan ──────────────────────────────────────────────
# Wajib diisi! Gunakan nilai acak, contoh:
# SECRET_KEY=abcd1234efgh5678ijkl9012mnop3456qrst
SECRET_KEY=

# ─── Database ───────────────────────────────────────────────
# Default: SQLite di instance/users.db (tidak perlu diubah)
# DATABASE_URL=sqlite:///instance/users.db

# ─── API CoinGecko (opsional) ───────────────────────────────
# Kosongkan untuk menggunakan tier demo (tanpa API key).
# Jika diisi, header x-cg-demo-api-key akan dikirim.
# COINGECKO_API_KEY=
API_TIMEOUT=10

# ─── Cache TTL (detik) ──────────────────────────────────────
MARKET_CACHE_TTL=300
DETAIL_CACHE_TTL=300
HISTORY_CACHE_TTL=600
PREDICTION_CACHE_TTL=3600

# ─── Default Admin ──────────────────────────────────────────
# Aplikasi akan membuat admin default secara otomatis
# jika AUTO_CREATE_DEFAULT_ADMIN=true dan belum ada admin.
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@example.local
DEFAULT_ADMIN_PASSWORD=Admin1234
AUTO_CREATE_DEFAULT_ADMIN=true

# ─── Flask ──────────────────────────────────────────────────
FLASK_DEBUG=false
FLASK_ENV=default
PORT=5050
